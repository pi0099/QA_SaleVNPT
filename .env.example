NEXT_PUBLIC_SITE_URL=https://www.ketnoimanghcm.vn

# Vercel Blob — bắt buộc để lưu CMS trên production (Admin → Save).
# Tạo Blob store trên Vercel Dashboard → Storage → Blob; env tự gán BLOB_READ_WRITE_TOKEN.
BLOB_READ_WRITE_TOKEN=

# Google Search Console HTML tag verification content.
# Example: <meta name="google-site-verification" content="abc123" />
# Put only: abc123
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 measurement ID, for example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Google Tag Manager container ID, for example: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
